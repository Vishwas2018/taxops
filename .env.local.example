# Copy to .env.local. Values below match `supabase start` output for local dev
# (`npx supabase status` reprints them). Port is 54331, not the Supabase default 54321 —
# this machine already runs another local Supabase project on the default ports (see
# supabase/config.toml).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
# Either the legacy JWT "anon key" or the newer "publishable key" works here — both are
# printed by `supabase status`. We use the publishable key since it's Supabase's current
# recommended default.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
